#include <LedControl.h>

// DIN, CLK, CS, number of devices = 3
LedControl lc = LedControl(11, 13, 10, 3);

// ---------- MALE SYMBOL ----------
byte maleSymbol[8] = {
  B00011000,
  B00111100,
  B00011000,
  B01111110,
  B00011000,
  B00100100,
  B01000010,
  B00000000
};

// ---------- FEMALE SYMBOL ----------
byte femaleSymbol[8] = {
  B00011000,
  B00111100,
  B00011000,
  B00111100,
  B01011010,
  B00011000,
  B00100100,
  B00000000
};

void setup() {
  for (int i = 0; i < 3; i++) {
    lc.shutdown(i, false);
    lc.setIntensity(i, 8);
    lc.clearDisplay(i);
  }

  randomSeed(analogRead(0)); // Seed randomness
}

void loop() {
  // -------- First display (Male) --------
  for (int row = 0; row < 8; row++) {
    lc.setRow(0, row, maleSymbol[row]);
  }

  // -------- Third display (Female) --------
  for (int row = 0; row < 8; row++) {
    lc.setRow(2, row, femaleSymbol[row]);
  }

  // -------- Middle display (Random) --------
  bool showMale = random(0, 2); // 0 or 1

  for (int row = 0; row < 8; row++) {
    if (showMale) {
      lc.setRow(1, row, maleSymbol[row]);
    } else {
      lc.setRow(1, row, femaleSymbol[row]);
    }
  }

  delay(2000); // Change every 2 seconds
}
